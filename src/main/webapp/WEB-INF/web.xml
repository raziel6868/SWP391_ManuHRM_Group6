<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>UserProfileEditServlet</servlet-name>
        <servlet-class>controller.user.UserProfileEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserProfileEditServlet</servlet-name>
        <url-pattern>/profile/edit</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <!-- Mặc định tự động map vào URL /home của HomeServlet -->
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>
    <!-- Định nghĩa Filter -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filter.AuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>RbacFilter</filter-name>
        <filter-class>filter.RbacFilter</filter-class>
    </filter>
    <!-- THỨ TỰ ƯU TIÊN CHẠY FILTERS  -->
    <!-- Bước 1: Kiểm tra xem đã đăng nhập chưa -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <!-- Bước 2: Kiểm tra xem có quyền truy cập URL đó không -->
    <filter-mapping>
        <filter-name>RbacFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <!-- Điều hướng trang báo lỗi -->
    <!-- Lỗi 403: Cấm truy cập (Không có quyền) -->
    <error-page>
        <error-code>403</error-code>
        <location>/views/error/403.jsp</location>
    </error-page>
    <!-- Lỗi 404: Trang không tồn tại -->
    <error-page>
        <error-code>404</error-code>
        <location>/views/error/404.jsp</location>
    </error-page>
    <!-- Lỗi 500: Exception / Sập logic trong code -->
    <error-page>
        <error-code>500</error-code>
        <location>/views/error/500.jsp</location>
    </error-page>
</web-app>
